		"format": "п‚  {percentage_used}%",
		"format-alt": "п‚  {used}/{total}",
		"path": "/",
		"unit": "GiB",
		"interval": 1,
		"states": {
			"default": 20,
			"warning": 50,
			"critical": 99
		},
		"tooltip": false
	},
	"custom/wttrbar": {
		"exec": "wttrbar --nerd --lang ru --location Lozova+Moldova",
		"format": "{}В°",
		"interval": 1,
		"return-type": "json"
	},
	"clock": {
