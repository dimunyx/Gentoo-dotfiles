    			"balanced": "п†Ћ",
    			"power-saver": "пЂљ"
  		},
		"tooltip": false
	},
	"custom/hypr-ver": {
		"exec": "Hyprland --version | head -n1 | awk '{print $2}'",
		"format": "пЌ™ {}",
		"tooltip": false
	},
	"custom/kernel-ver": {
		"exec": "uname -r",
		"format": "оЇ† {}",
		"tooltip": false
	},
	
	"custom/cava": {
		"exec": "/home/dimunyx/.config/waybar/scripts/cava.sh",
		"format": "у°Ћ‡ {}",
		"tooltip": false
	},

	"tray": {
		"icon-size": 16,
		"spacing": 2
	},
	"hyprland/workspaces": {
		"format": "{icon}",
		"format-icons": {
			"active": "о©±",
			"empty": "",
			"default": "оЄј",
			"urgent": "!"
		},
		"on-scroll-up": "/home/dimunyx/.config/waybar/scripts/prev-ws.sh",
		"on-scroll-down": "/home/dimunyx/.config/waybar/scripts/next-ws.sh",
		"persistent-workspaces": {
			"*": 10
		},
		"tooltip": false
	},
	"hyprland/language": {
		"format": "п„њ {short}",
